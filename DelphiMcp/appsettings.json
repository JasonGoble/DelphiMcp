{
  "Embedder": {
    "Provider": "OpenAI"
  },
  "OpenAI": {
    "ApiKey": ""
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "nomic-embed-text"
  },
  "Storage": {
    "DbPath": "",
    "FaissIndexDir": ""
  },
  "Server": {
    "Mode": "stdio"
  },
  "Hosted": {
    "Path": "/mcp",
    "ApiKey": "",
    "RequireHttps": false
  },
  "ClientAccess": {
    "GlobalPolicy": {
      "MaxTopK": 10,
      "MaxVersionsPerLibraryPerQuery": 2,
      "MaxTargetScopesPerQuery": 4,
      "AllowUnversionedQueries": true,
      "RequireVersionWhenLibrarySpecified": false,
      "DefaultSearchBehavior": "UseProfileDefaults"
    },
    "Profiles": {
      "sample-machine": {
        "Enabled": false,
        "DisplayName": "Sample Machine Profile",
        "ApiKeyRef": "MCP__KEY__SAMPLE_MACHINE",
        "DefaultScopes": [
          {
            "Library": "rtl",
            "Version": "13.1"
          },
          {
            "Library": "devexpress",
            "Version": "25.2.6"
          }
        ],
        "Options": {
          "MaxTopK": 8
        }
      }
    }
  },
  "Search": {
    "PrioritizedNamespaces": [
      "System",
      "Vcl",
      "FMX",
      "FireDAC"
    ],
    "NamespaceBoostFactor": 0.95,
    "NamespaceOversampleFactor": 5
  }
}
